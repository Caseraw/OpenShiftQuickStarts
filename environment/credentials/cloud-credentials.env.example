# Cloud provider credentials — source this file or copy the relevant section.
# Set CLOUD_PROVIDER in env.sh to the matching value below.

# =============================================================================
# AWS  (CLOUD_PROVIDER=aws)
# =============================================================================
AWS_ACCESS_KEY_ID="<your-access-key-id>"
AWS_SECRET_ACCESS_KEY="<your-secret-access-key>"
AWS_DEFAULT_REGION="us-east-1"

# =============================================================================
# Azure  (CLOUD_PROVIDER=azure)
# =============================================================================
AZURE_SUBSCRIPTION_ID="<your-subscription-id>"
AZURE_TENANT_ID="<your-tenant-id>"
AZURE_CLIENT_ID="<your-client-id>"
AZURE_CLIENT_SECRET="<your-client-secret>"
AZURE_RESOURCE_GROUP="<your-resource-group>"
AZURE_REGION="eastus"

# =============================================================================
# GCP  (CLOUD_PROVIDER=gcp)
# =============================================================================
GCP_PROJECT_ID="<your-project-id>"
GCP_REGION="us-central1"
# Path to your GCP service account JSON key file (absolute or relative to repo root)
GCP_SERVICE_ACCOUNT_KEY_FILE="environment/credentials/gcp-service-account.json"
