#!/usr/bin/env bash
# env.sh.example — Template for environment configuration.
#
# Copy this file to env.sh and fill in the values for your cluster.
# env.sh is gitignored and will never be committed.
#
#   cp environment/env.sh.example environment/env.sh
#   # edit environment/env.sh
#   make env-check
#
# All variables are optional when you are already logged in via 'oc login';
# scripts will auto-detect cluster identity from the live cluster where
# possible and fall back to these values otherwise.

# =============================================================================
# Cluster identity
# Auto-detected from 'oc' if not set.
# =============================================================================

# Base domain of the cluster API server, e.g. cluster-abc.example.com
# Derived automatically from 'oc whoami --show-server' if left empty.
export CLUSTER_NAME=""

# Full API server URL, e.g. https://api.cluster-abc.example.com:6443
# Derived automatically from 'oc whoami --show-server' if left empty.
export CLUSTER_API_URL=""

# Wildcard app domain, e.g. apps.cluster-abc.example.com
# Derived automatically from 'oc get ingresses.config cluster' if left empty.
export CLUSTER_APP_DOMAIN=""

# OCP version string, e.g. 4.21
# Derived automatically from 'oc version' if left empty.
export OCP_VERSION=""

# =============================================================================
# Cloud provider
# =============================================================================

# Cloud provider where cluster nodes are running.
# Values: aws | azure | gcp | baremetal | vsphere | none
# Derived automatically from 'oc get infrastructure cluster' if left empty.
export CLOUD_PROVIDER=""

# =============================================================================
# Credential file paths
# Paths are relative to the repository root unless absolute.
# Default values point to the standard locations in environment/credentials/.
# =============================================================================

# Absolute path to the repository root (auto-set by scripts — do not change).
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export CREDENTIALS_DIR="${REPO_ROOT}/environment/credentials"

# Red Hat / quay.io pull secret (JSON format).
# Required for installing Red Hat operators (RHACM, Pipelines, etc.).
# Get yours at: https://console.redhat.com → OpenShift → Downloads → Pull secret
export PULL_SECRET_FILE="${CREDENTIALS_DIR}/pull-secret.json"

# SSH public key for node access or Git repository authentication.
export SSH_PUBLIC_KEY_FILE="${CREDENTIALS_DIR}/ssh-public-key"

# SSH private key for node access or Git repository authentication.
export SSH_PRIVATE_KEY_FILE="${CREDENTIALS_DIR}/ssh-private-key"

# Cloud provider credentials file (bash env-var format, sourced at runtime).
# Copy cloud-credentials.env.example and fill in the relevant section.
export CLOUD_CREDENTIALS_FILE="${CREDENTIALS_DIR}/cloud-credentials.env"

# =============================================================================
# Multi-cluster topology
# The hub cluster is the primary cluster (where RHACM is or will be installed).
# Spoke clusters are managed clusters imported into the hub.
# =============================================================================

# --- Hub cluster -------------------------------------------------------------
# The cluster that runs RHACM. All 'oc login' and scenario operations default
# to this cluster unless a spoke-specific context is explicitly activated.

# Full API server URL of the hub cluster.
export HUB_API_URL=""

# Web console URL of the hub cluster (informational).
export HUB_CONSOLE_URL=""

# Credentials for the hub cluster.
export HUB_USERNAME=""
export HUB_PASSWORD=""

# Convenience alias — CLUSTER_* vars default to the hub cluster.
export CLUSTER_API_URL="${HUB_API_URL}"
export CLUSTER_APP_DOMAIN=""   # e.g. apps.cluster-abc.example.com

# --- Spoke clusters ----------------------------------------------------------
# Number of spoke clusters defined below.
export SPOKE_COUNT=0

# Spoke 1
export SPOKE1_NAME="spoke-1"          # Name used when importing into RHACM
export SPOKE1_API_URL=""
export SPOKE1_CONSOLE_URL=""
export SPOKE1_USERNAME=""
export SPOKE1_PASSWORD=""

# Spoke 2
export SPOKE2_NAME="spoke-2"
export SPOKE2_API_URL=""
export SPOKE2_CONSOLE_URL=""
export SPOKE2_USERNAME=""
export SPOKE2_PASSWORD=""

# Add SPOKE3_*, SPOKE4_*, … as needed and increment SPOKE_COUNT.

# =============================================================================
# Component-specific configuration
# =============================================================================

# --- RHACM (components/rhacm) ------------------------------------------------
# OLM channel for the RHACM operator. Default: release-2.17
export RHACM_CHANNEL="release-2.17"

# --- Red Hat Quay (future component) -----------------------------------------
# export QUAY_HOSTNAME=""
# export QUAY_ADMIN_PASSWORD_FILE="${CREDENTIALS_DIR}/quay-admin-password"

# --- OpenShift GitOps (future component) -------------------------------------
# export GITOPS_REPO_URL=""
# export GITOPS_REPO_TOKEN_FILE="${CREDENTIALS_DIR}/gitops-repo-token"
